#!/bin/zsh

[ -r "$HOME/.config/shell/env.sh" ] && . "$HOME/.config/shell/env.sh"

# NOTE: do not autostart GUI sessions over SSH
if [ -n "$SSH_CLIENT" ] || [ -n "$SSH_TTY" ]; then
    return 0 2>/dev/null || exit 0
fi

export PATH="$HOME/.local/bin:$HOME/bin:/usr/local/bin:$HOME/.cargo/bin:$HOME/.dotnet/bin:$HOME/.dotnet/tools:$PATH"

# NOTE: Reset .ctx on every login
rm -f "$HOME/.ctx"

# NOTE: Normal/default behavior: only autostart from tty1.
is_autostart_tty=false
[ "$(tty)" = "/dev/tty1" ] && is_autostart_tty=true

# NOTE: For temporary testing on any TTY, uncomment this:
# is_autostart_tty=true

if [ -n "$DISPLAY" ] || [ -n "$WAYLAND_DISPLAY" ]; then
    return 0 2>/dev/null || exit 0
fi

if [ "$is_autostart_tty" != true ]; then
    return 0 2>/dev/null || exit 0
fi

gui="$(
    awk '
        {
            sub(/[[:space:]]*#.*/, "")
            gsub(/^[[:space:]]+|[[:space:]]+$/, "")
        }
        NF {
            print
            exit
        }
    ' "$HOME/.config/ui" 2>/dev/null
)"
: "${gui:=hypr}"

case "$gui" in
    xorg|i3)
        xorg_envs
        exec startx "$HOME/.xinitrc-i3"
        ;;

    wayland|hyprland|hypr)
        wayland_envs
        exec uwsm start start-hyprland
        ;;

    *)
        printf 'Invalid ~/.config/ui value: %s\nExpected: xorg or wayland\n' "$gui" >&2
        ;;
esac
